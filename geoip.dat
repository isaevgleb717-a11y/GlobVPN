# Группируем по странам
countries = {}
for start_ip, end_ip, country in records:
    if country not in countries:
        countries[country] = []
    countries[country].append((ip_to_int(start_ip), ip_to_int(end_ip)))

# Создаем бинарный файл в формате V2Ray GeoIP
with open('geoip.dat', 'wb') as f:
    # Заголовок файла
    f.write(b'GEOIP\x00\x00\x00\x01')  # Магическое число и версия
    
    # Количество стран
    f.write(struct.pack('<I', len(countries)))
    
    # Для каждой страны
    for country_code, ranges in countries.items():
        # Код страны (2 байта)
        f.write(country_code.encode('ascii'))
        
        # Количество диапазонов
        f.write(struct.pack('<I', len(ranges)))
        
        # Диапазоны IP
        for start, end in ranges:
            f.write(struct.pack('<II', start, end))

print("Файл geoip.dat успешно создан!")
print(f"Добавлено стран: {len(countries)}")
print(f"Всего диапазонов: {len(records)}")
EOF